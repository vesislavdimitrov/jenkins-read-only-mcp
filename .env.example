# Jenkins MCP server configuration
# Copy this file to .env and adjust values, or export them in your shell.

# Jenkins base URL (no trailing slash needed; one is stripped)
JENKINS_URL=http://your-jenkins-host:8080

# Jenkins credentials for authenticated access (optional — leave blank for anonymous)
JENKINS_USER=your-user
JENKINS_TOKEN=your-token

# Per-request HTTP timeout in seconds
JENKINS_TIMEOUT=10

# HTTP transport (only used with `python server.py --http`)
HTTP_HOST=0.0.0.0
PORT=8000

# DNS-rebinding protection for the HTTP transport. Default false because the
# server is typically reached by short hostname / FQDN / IP from the same network.
# Set to true to enable the allowlist check.
ENABLE_DNS_REBINDING_PROTECTION=false
